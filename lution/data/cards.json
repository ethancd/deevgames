  {
    "id": "r2-claude-the-audit-trail",
    "name": "The Audit Trail",
    "effectText": "Keeper. Worth 1 point while in play. At the start of an opponent's turn, if they have more keepers in play than you, you draw a card.",
    "creatorId": "claude",
    "createdInRound": 2,
    "destroyed": false,
    "implemented": true,
    "composition": {
      "cardType": "keeper",
      "baseValue": 1,
      "effects": [
        {
          "trigger": "onTurnStart",
          "side": "opponent",
          "body": {
            "type": "if",
            "condition": {
              "type": "compare",
              "left": {
                "type": "count",
                "selector": {
                  "zone": "inPlay",
                  "owner": "opponent",
                  "pick": "all"
                }
              },
              "op": ">",
              "right": {
                "type": "count",
                "selector": {
                  "zone": "inPlay",
                  "owner": "self",
                  "pick": "all"
                }
              }
            },
            "then": {
              "type": "seq",
              "steps": [
                {
                  "atom": "log",
                  "message": "{owner}'s {card} notices the opponent is ahead on keepers and files a draw."
                },
                {
                  "atom": "draw",
                  "target": "self"
                }
              ]
            }
          }
        }
      ],
      "strategy": {
        "playValue": 1,
        "stealTargetValue": 1
      }
    }
  },
