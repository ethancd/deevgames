{
  "name": "@mms/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vite + React + TS PWA. App shell, deploy pipeline, and game screens.",
  "scripts": {
    "sync:content": "node scripts/sync-content.mjs",
    "dev": "pnpm sync:content && vite",
    "build": "pnpm sync:content && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mms/data": "workspace:*",
    "@mms/engine": "workspace:*",
    "@mms/schema": "workspace:*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.0.16"
  }
}
