  {
    "id": "r4-human-subzero-serpent",
    "name": "Subzero Serpent",
    "effectText": "Keeper, worth 1 point. At the start of each turn, freeze a non-frozen keeper in play; if you can’t, this card is discarded. Frozen keepers are worth 1 point.",
    "creatorId": "human",
    "createdInRound": 4,
    "destroyed": false,
    "implemented": true,
    "composition": {
      "cardType": "keeper",
      "baseValue": 1,
      "effects": [
        {
          "trigger": "onTurnStart",
          "side": "any",
          "body": {
            "type": "if",
            "condition": {
              "type": "selectorNonEmpty",
              "selector": {
                "zone": "inPlay",
                "owner": "any",
                "filter": {
                  "type": "not",
                  "filter": {
                    "type": "frozen"
                  }
                },
                "pick": "all"
              }
            },
            "then": {
              "type": "seq",
              "steps": [
                {
                  "atom": "freezeInPlay",
                  "selector": {
                    "zone": "inPlay",
                    "owner": "any",
                    "filter": {
                      "type": "not",
                      "filter": {
                        "type": "frozen"
                      }
                    },
                    "pick": "chooser",
                    "chooser": "self"
                  },
                  "to": {
                    "type": "literal",
                    "value": 1
                  },
                  "duration": "permanent"
                },
                {
                  "atom": "log",
                  "message": "{owner}'s {card} freezes {target} down to 1 point."
                }
              ]
            },
            "else": {
              "type": "seq",
              "steps": [
                {
                  "atom": "log",
                  "message": "{owner}'s {card} finds nothing left to freeze and slithers into the discard pile."
                },
                {
                  "atom": "destroy",
                  "selector": {
                    "zone": "inPlay",
                    "owner": "self",
                    "pick": "self"
                  }
                }
              ]
            }
          }
        }
      ],
      "strategy": {
        "playValue": 1.5,
        "stealTargetValue": 1.5
      }
    }
  },
