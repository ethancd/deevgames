    "test:cards": "vitest run tests/structural.test.ts tests/cards"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198"
  }
}
